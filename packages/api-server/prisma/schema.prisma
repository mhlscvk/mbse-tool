generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String?
  role            Role      @default(EDITOR)
  emailVerified   Boolean   @default(false)
  verifyToken     String?   @unique
  verifyTokenExp  DateTime?
  googleId        String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  projects        Project[]
  aiUsage         AiUsage[]
  aiChatMessages  AiChatMessage[]
  mcpTokens       McpToken[]
  aiProviderKeys  AiProviderKey[]

  @@map("users")
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  files       SysMLFile[]

  @@index([ownerId])
  @@map("projects")
}

model SysMLFile {
  id        String   @id @default(cuid())
  name      String
  content   String   @db.Text
  size      Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  aiChatMessages  AiChatMessage[]

  @@map("sysml_files")
}

model AiUsage {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  periodStart   DateTime
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  requestCount  Int      @default(0)

  @@unique([userId, periodStart])
  @@map("ai_usage")
}

model AiChatMessage {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  file      SysMLFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileId    String
  role      String    // 'user' | 'assistant'
  text      String    @db.Text
  edits     Json?
  createdAt DateTime  @default(now())

  @@index([userId, fileId, createdAt])
  @@map("ai_chat_messages")
}

model McpToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String    @unique
  name      String    // e.g. "Claude Desktop", "Cursor"
  lastUsed  DateTime?
  expiresAt DateTime?
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId, revoked])
  @@map("mcp_tokens")
}

model AiProviderKey {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  provider      String   // 'anthropic' | 'openai' | 'gemini'
  encryptedKey  String   @db.Text
  iv            String
  authTag       String
  maskedKey     String   // e.g. "sk-ant-...3yQ"
  model         String   // default model for this provider
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, provider])
  @@map("ai_provider_keys")
}

enum Role {
  VIEWER
  EDITOR
  ADMIN
}
