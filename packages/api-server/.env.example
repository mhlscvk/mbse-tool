PORT=3003
DATABASE_URL=postgresql://postgres:password@localhost:5432/systemodel
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# AI encryption key for storing user API keys (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_ENCRYPTION_KEY=

# Free tier AI: server-side Anthropic key (optional — enables free tier for users)
ANTHROPIC_API_KEY=
AI_MONTHLY_LIMIT=50

# Google OAuth (optional — enables Google Sign-In)
GOOGLE_CLIENT_ID=

# SMTP for email verification and password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Systemodel" <noreply@systemodel.com>

# Application URL (used in emails and redirects)
APP_URL=http://localhost:5173
